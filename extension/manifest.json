{
  "manifest_version": 3,
  "name": "YT Download+",
  "description": "Ajoute une interface YT Download+ intégrée aux pages YouTube pour préparer un téléchargement.",
  "version": "0.1.0",
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://m.youtube.com/*"],
      "js": ["src/config.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["https://www.youtube.com/*", "https://m.youtube.com/*", "http://localhost:3000/*", "https://*.vercel.app/*"],
  "permissions": ["storage", "downloads"],
  "browser_specific_settings": {
    "gecko": {
      "id": "yt-download-plus@example.local",
      "strict_min_version": "109.0"
    }
  }
}
